{
  "type": "web",
  "response": {
    "output": "{{body}}"
  },
  "verification": {
    "condition": "{{hmac('sha256', headers['x-payzcore-timestamp'] + '.' + body, parameters.webhookSecret) == headers['x-payzcore-signature']}}",
    "respond": {
      "status": 401,
      "body": "{\"error\": \"Invalid signature\"}"
    }
  }
}
